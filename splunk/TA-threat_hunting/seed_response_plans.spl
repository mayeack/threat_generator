| makeresults
| eval plan_id="T1105",
       mitre_technique_id="T1105",
       technique_name="Ingress Tool Transfer",
       security_domain="network",
       containment_steps="1. Block outbound communication to the C2 IP at the perimeter firewall\n2. Isolate the affected host from the network\n3. Preserve volatile memory and disk image before remediation\n4. Block the C2 domain/IP across all egress points (proxy, DNS sinkhole, firewall)",
       investigation_steps="1. Run drilldown search to review all HTTP/HTTPS communications to the C2 IP\n2. Identify all files downloaded from the C2 server (check URI paths, content lengths)\n3. Search for the downloaded binary hash across all endpoints\n4. Check for lateral movement originating from the affected host\n5. Review process execution logs for post-download activity on the affected host\n6. Cross-reference the C2 IP with threat intelligence feeds",
       eradication_steps="1. Remove all downloaded binaries and associated files from the affected host\n2. Scan the host for additional malware or persistence mechanisms\n3. Verify no scheduled tasks, services, or registry keys were created by the payload\n4. Reset credentials for any accounts that were active on the compromised host",
       recovery_steps="1. Re-image the host if persistence or additional compromise is confirmed\n2. Restore from known-good backup if available and verified clean\n3. Reconnect to network with enhanced monitoring for 72 hours\n4. Validate the host is functioning normally and no C2 callbacks resume",
       escalation_criteria="Escalate to IR team if: lateral movement confirmed, data exfiltration detected, additional hosts communicating with the same C2, or the binary is identified as a known APT tool"
